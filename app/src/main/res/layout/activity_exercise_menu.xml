<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#008B8B"
    android:padding="20dp">

    <!-- Back Button pojok kiri atas -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_marginTop="36dp"
        android:src="@android:drawable/ic_media_previous"
        android:background="@drawable/bg_close_btn"
        android:tint="#FFFFFF"
        android:padding="8dp"
        android:contentDescription="Kembali"/>

    <!-- App Title -->
    <TextView
        android:id="@+id/tv_app_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="40dp"
        android:text="FitLife"
        android:textColor="#FFFFFF"
        android:textSize="40sp"
        android:fontFamily="serif"
        android:textStyle="italic"/>

    <!-- Menu Container Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/menu_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tv_app_title"
        android:layout_marginTop="30dp"
        app:cardBackgroundColor="#0A5F5F"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tv_menu_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Menu Latihan"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#FFFFFF"
                android:layout_marginBottom="20dp"/>

            <!-- Running Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_running"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="15dp"
                android:foreground="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#0A5F5F"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="15dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="☆"
                        android:textColor="#FFFFFF"
                        android:textSize="24sp"
                        android:layout_marginEnd="15dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_running_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Berlari"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="5dp"/>

                        <TextView
                            android:id="@+id/tv_running_desc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lacak jarak lari, waktu, dan kalori yang terbakar. Tetap termotivasi dengan informasi perkembangan dan target harian."
                            android:textColor="#B3FFFFFF"
                            android:textSize="13sp"
                            android:lineSpacingExtra="2dp"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⇄"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:layout_marginStart="10dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Push-up Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_pushup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="15dp"
                android:foreground="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#0A5F5F"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="15dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="☆"
                        android:textColor="#FFFFFF"
                        android:textSize="24sp"
                        android:layout_marginEnd="15dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_pushup_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Push-up"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="5dp"/>

                        <TextView
                            android:id="@+id/tv_pushup_desc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hitung push-up Anda, pantau setnya, dan pantau kalori yang terbakar. Bangun kekuatan tubuh bagian atas selangkah demi selangkah."
                            android:textColor="#B3FFFFFF"
                            android:textSize="13sp"
                            android:lineSpacingExtra="2dp"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⇄"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:layout_marginStart="10dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Yoga Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_yoga"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:foreground="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#0A5F5F"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="15dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="☆"
                        android:textColor="#FFFFFF"
                        android:textSize="24sp"
                        android:layout_marginEnd="15dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_yoga_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Yoga"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="5dp"/>

                        <TextView
                            android:id="@+id/tv_yoga_desc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ikuti sesi yoga terpandu, tingkatkan fleksibilitas, dan rilekskan pikiran Anda dengan rutinitas yang menenangkan."
                            android:textColor="#B3FFFFFF"
                            android:textSize="13sp"
                            android:lineSpacingExtra="2dp"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⇄"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:layout_marginStart="10dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- FAB + Label wrapper — pojok kanan bawah -->
    <LinearLayout
        android:id="@+id/fabWrapper"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="24dp">

        <!-- FAB Coach AI -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabCoachAI"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_bot_avatar"
            android:contentDescription="@string/fab_coach_desc"
            app:backgroundTint="@color/teal_primary"
            app:tint="@color/white"
            app:elevation="8dp"
            app:pressedTranslationZ="12dp"/>

        <!-- Label Coach AI di bawah FAB -->
        <TextView
            android:id="@+id/tvFabLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Coach AI"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

</RelativeLayout>