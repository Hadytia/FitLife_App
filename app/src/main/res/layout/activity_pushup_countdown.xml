<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#008B8B"
    android:padding="30dp">

    <TextView
        android:id="@+id/tv_countdown_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_marginTop="60dp"
        android:text="Push-Up"
        android:textColor="#FFFFFF"
        android:textSize="48sp"
        android:fontFamily="serif"
        android:textStyle="italic"/>

    <FrameLayout
        android:id="@+id/countdown_container"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_centerInParent="true">

        <View
            android:id="@+id/circle_background"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/circle_green"/>

        <TextView
            android:id="@+id/tv_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="140sp"
            android:fontFamily="@font/digital7_mono"/>

    </FrameLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/countdown_container"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/tv_label_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Siap Mulai?"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_instruction_sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Letakkan dada di atas HP"
            android:textColor="#CCFFFFFF"
            android:textSize="14sp"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btn_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="50dp"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btn_back"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:text="@string/btn_back"
            android:textColor="#FFFFFF"
            android:backgroundTint="#33000000"
            app:cornerRadius="12dp"
            android:textStyle="bold"
            android:textAllCaps="false"/>

        <Button
            android:id="@+id/btn_start"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="@string/btn_start"
            android:textColor="@color/teal_primary"
            android:backgroundTint="@color/white"
            app:cornerRadius="12dp"
            android:textStyle="bold"
            android:textAllCaps="false"/>

        <Button
            android:id="@+id/btn_restart"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="RESTART"
            android:textColor="#FFFFFF"
            android:backgroundTint="#33000000"
            app:cornerRadius="12dp"
            android:textStyle="bold"
            android:visibility="gone"
            android:textAllCaps="false"/>

        <Button
            android:id="@+id/btn_menu"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="MENU"
            android:textColor="#FFFFFF"
            android:backgroundTint="#33000000"
            app:cornerRadius="12dp"
            android:textStyle="bold"
            android:visibility="gone"
            android:textAllCaps="false"/>

    </LinearLayout>

    <!-- FAB Label -->
    <TextView
        android:id="@+id/tvFabLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/fab_coach_label"
        android:textSize="11sp"
        android:textColor="@color/white"
        android:background="@drawable/bg_bubble_user"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:layout_above="@id/btn_container"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="72dp"
        android:layout_marginBottom="8dp"/>

    <!-- FAB Coach AI -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabCoachAI"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@id/btn_container"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:src="@drawable/ic_bot_avatar"
        android:contentDescription="@string/fab_coach_desc"
        app:backgroundTint="@color/teal_primary"
        app:tint="@color/white"
        app:elevation="6dp"/>

</RelativeLayout>