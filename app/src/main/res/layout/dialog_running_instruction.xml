<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="20dp">

    <!-- Dialog Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="20dp"
        app:cardElevation="10dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="25dp">

            <!-- Close Button (X) -->
            <TextView
                android:id="@+id/btn_close_dialog"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_alignParentTop="true"
                android:text="×"
                android:textSize="28sp"
                android:textColor="#666666"
                android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"/>

            <!-- Dialog Title -->
            <TextView
                android:id="@+id/tv_dialog_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/btn_close_dialog"
                android:layout_marginTop="10dp"
                android:text="Instruksi Berlari"
                android:textColor="#000000"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginEnd="30dp"/>

            <!-- Instructions Text -->
            <ScrollView
                android:id="@+id/scroll_instructions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/tv_dialog_title"
                android:layout_marginTop="20dp"
                android:maxHeight="350dp">

                <TextView
                    android:id="@+id/tv_instruction"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1. Awali dengan pemanasan berjalan kaki selama 2-3 menit.\n\n2. Jaga postur tubuh tetap tegak dan bahu rileks.\n\n3. Mendaratlah dengan posisi setengah kaki dan dorong dengan jari-jari kaki.\n\n4. Ayunkan lengan 90 derajat dan bernapaslah dengan teratur.\n\n5. Pendinginan dengan berjalan kaki perlahan."
                    android:textColor="#333333"
                    android:textSize="16sp"
                    android:lineSpacingExtra="4dp"/>
            </ScrollView>

            <!-- Buttons Container -->
            <LinearLayout
                android:id="@+id/buttons_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/scroll_instructions"
                android:layout_marginTop="25dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:weightSum="2">

                <!-- Back Button -->
                <Button
                    android:id="@+id/btn_back_dialog"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Kembali"
                    android:textColor="#666666"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:background="@drawable/btn_dialog_back"
                    android:textAllCaps="false"/>

                <!-- Start Button -->
                <Button
                    android:id="@+id/btn_start_dialog"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Mulai"
                    android:textColor="#666666"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:background="@drawable/btn_dialog_start"
                    android:textAllCaps="false"/>

            </LinearLayout>

        </RelativeLayout>

    </androidx.cardview.widget.CardView>

</RelativeLayout>