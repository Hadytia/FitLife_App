<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#008B8B"
    android:padding="16dp">

    <!-- Title -->
    <TextView
        android:id="@+id/tv_countdown_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="16dp"
        android:text="Yoga"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:fontFamily="serif"
        android:textStyle="italic|bold"/>

    <!-- Pose Info Section -->
    <LinearLayout
        android:id="@+id/pose_info_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tv_countdown_title"
        android:layout_marginTop="8dp"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Silhouette Container - EVEN LARGER -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_silhouette"
            android:layout_width="240dp"
            android:layout_height="240dp"
            app:cardCornerRadius="120dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#22FFFFFF"
            android:layout_marginBottom="12dp">

            <ImageView
                android:id="@+id/iv_pose_silhouette"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="10dp"
                android:scaleType="fitCenter"
                android:src="@drawable/pose_mountain"
                android:contentDescription="Yoga Pose"/>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tv_pose_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Siap Mulai?"
            android:textColor="#FFFFFF"
            android:textSize="36sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingHorizontal="20dp"/>

        <TextView
            android:id="@+id/tv_pose_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sesi Yoga Terpandu"
            android:textColor="#CCFFFFFF"
            android:textSize="18sp"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- Pulsing Breathing Circle - LARGE CONTAINER -->
    <FrameLayout
        android:id="@+id/countdown_container"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:layout_centerInParent="true"
        android:layout_below="@id/pose_info_container">

        <View
            android:id="@+id/circle_background"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_gravity="center"
            android:background="@drawable/circle_green"
            android:alpha="0.4"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_countdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00"
                android:textColor="#FFFFFF"
                android:textSize="56sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_breathing"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#FFFFFF"
                android:textSize="34sp"
                android:textStyle="bold"
                android:layout_marginTop="-5dp"/>
        </LinearLayout>
    </FrameLayout>

    <!-- Buttons Container -->
    <LinearLayout
        android:id="@+id/btn_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="10dp"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btn_back"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="BACK"
            android:textColor="#FFFFFF"
            android:backgroundTint="#33000000"
            app:cornerRadius="12dp"
            android:textStyle="bold"
            android:textAllCaps="false"/>

        <Button
            android:id="@+id/btn_start"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="START"
            android:textColor="@color/teal_primary"
            android:backgroundTint="@color/white"
            app:cornerRadius="12dp"
            android:textStyle="bold"
            android:textAllCaps="false"/>

        <Button
            android:id="@+id/btn_restart"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="RESTART"
            android:textColor="#FFFFFF"
            android:backgroundTint="#33000000"
            app:cornerRadius="12dp"
            android:textStyle="bold"
            android:visibility="gone"
            android:textAllCaps="false"/>

        <Button
            android:id="@+id/btn_menu"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="MENU"
            android:textColor="#FFFFFF"
            android:backgroundTint="#33000000"
            app:cornerRadius="12dp"
            android:textStyle="bold"
            android:visibility="gone"
            android:textAllCaps="false"/>
    </LinearLayout>

</RelativeLayout>