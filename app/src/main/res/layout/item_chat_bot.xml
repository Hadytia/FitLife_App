<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="8dp"
    android:paddingEnd="48dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp"
    android:gravity="start">

    <!-- Avatar lingkaran robot -->
    <FrameLayout
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="4dp">

        <View
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_avatar_circle"/>

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_robot"/>

    </FrameLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvBotMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="240dp"
            android:background="@drawable/bg_bubble_bot"
            android:padding="10dp"
            android:textColor="@color/bubble_bot_text"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.4"
            android:text="Pesan bot"/>

        <TextView
            android:id="@+id/tvBotTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="@color/timestamp_text"
            android:layout_marginTop="3dp"
            android:layout_marginStart="4dp"/>

    </LinearLayout>

</LinearLayout>